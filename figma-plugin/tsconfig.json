{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["es6", "dom", "es2017"],
    "module": "commonjs",
    "typeRoots": ["../node_modules/@types", "../node_modules/@figma"],
    "types": ["@figma/plugin-typings"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
